{
  "name": "tranfi",
  "version": "0.1.2",
  "description": "Streaming ETL language + runtime",
  "type": "commonjs",
  "main": "src/index.js",
  "bin": {
    "tranfi": "src/cli.js"
  },
  "exports": {
    ".": {
      "require": "./src/index.js",
      "default": "./src/index.js"
    },
    "./wasm": {
      "require": "./wasm/index.js",
      "default": "./wasm/index.js"
    }
  },
  "files": [
    "src/",
    "wasm/",
    "csrc/",
    "app/",
    "napi_api.c",
    "binding.gyp",
    "scripts/",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "prepack": "node scripts/prepack.js",
    "install": "node scripts/install-native.js",
    "build:native": "node scripts/sync-csrc.js && node-gyp rebuild",
    "test": "node ../test/test_node.js"
  },
  "peerDependencies": {
    "duckdb": ">=1.0.0",
    "@duckdb/duckdb-wasm": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "duckdb": {
      "optional": true
    },
    "@duckdb/duckdb-wasm": {
      "optional": true
    }
  },
  "keywords": [
    "etl",
    "csv",
    "streaming",
    "data",
    "pipeline",
    "transform"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/tranfi/tranfi"
  },
  "devDependencies": {
    "duckdb": "^1.4.4"
  },
  "author": "Anton Zemlyansky"
}
