{
  "name": "tranfi",
  "version": "0.0.1",
  "description": "Stream-based tool for file processing",
  "main": "src/main.js",
  "scripts": {
    "build-dev": "webpack --mode=development --progress --stats-children --env DEVELOPMENT",
    "build": "webpack --mode=production --progress && webpack --mode=production --progress --env RUNTIME",
    "watch": "nodemon --watch . --ignore dist --ext vue,js,css,html --exec 'npm run build-dev'",
    "prepublishOnly": "npm run build",
    "test": "jest test.js --detectOpenHandles",
    "test-head": "HEADLESS=false npm test"
  },
  "author": "Anton Zemlyansky",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tranfi/tranfi"
  },
  "dependencies": {
    "@jseeio/jsee": "^0.2.8",
    "buffer": "^6.0.3",
    "bulma": "^0.9.3",
    "csv-parse": "^4.16.3",
    "element-plus": "^1.2.0-beta.6",
    "equal-vue": "^0.79.3",
    "file-saver": "^2.0.2",
    "filestream": "^5.0.0",
    "filtrex": "^2.2.3",
    "JSONStream": "^1.3.5",
    "notyf": "^3.10.0",
    "process": "^0.11.10",
    "stream-browserify": "^3.0.0",
    "stream-http": "^3.2.0",
    "through2": "^4.0.2",
    "unzip-stream": "^0.3.1",
    "url": "^0.11.0",
    "vue": "^3.2.23",
    "vue-style-loader": "^4.1.3",
    "vue3-json-viewer": "^1.0.4",
    "vuedraggable": "^4.1.0",
    "vuex": "^4.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.16.5",
    "@babel/plugin-transform-runtime": "^7.4.4",
    "@babel/preset-env": "^7.16.5",
    "babel-loader": "^8.2.3",
    "css-loader": "^6.5.1",
    "http-server": "^14.0.0",
    "jest": "^27.4.5",
    "jest-puppeteer": "^6.0.3",
    "node-sass": "^7.0.0",
    "nodemon": "^2.0.15",
    "puppeteer": "^1.20.0",
    "sass-loader": "^12.4.0",
    "source-map-loader": "^3.0.0",
    "style-loader": "^3.3.1",
    "tape": "^4.9.1",
    "terser-webpack-plugin": "^5.3.0",
    "uglify-es": "^3.3.9",
    "vue-loader": "^17.0.0",
    "vue-template-compiler": "^2.6.14",
    "webpack": "^5.65.0",
    "webpack-cli": "^4.9.1",
    "worker-loader": "^3.0.8"
  }
}
